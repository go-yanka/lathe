# ephemeral runtime state — never versioned
__pycache__/
*.pyc
*.pyo
runs/
_fn_fails/
_artifact_fails/
docs/ce/
*.tmp
*.lock
_wp.txt
_writeprobe.txt
RUN_REPORT.md
tags

# secrets / local env / binaries — never versioned
*.db
.env
oracle-keys/
node_modules/
metrics/
*.db-journal
lathe.config.json
**/agents/_fetched/
**/agents/licenses/
**/agents/ratings.json

# per-invocation run manifests (#12 operating contract) — runtime evidence, per-user, not shipped
docs/ce/*.manifest.json
docs/ce/*.manifest.md

# per-environment test-ack approval state (keyed to test digest; human-in-loop, not shipped)
**/.test_ack.json

# per-environment assumption-gate machine state (spec digest + resolutions cache; the committed audit
# trail is <plan>.decisions.md, which IS versioned)
**/.assumptions.json
